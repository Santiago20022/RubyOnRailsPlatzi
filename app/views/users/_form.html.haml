-# frozen_string_literal: true
= simple_form_for(@user) do |f|
  = f.error_notification
  = f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present?

  .form-inputs
    = f.input :first_name, label: t('users.first_name'), as: :text
    = f.input :last_name, label: t('.last_name'), as: :text
    = f.input :address, label: t('.address'), as: :text
    = f.input :about_me, label: t('.about_me'), as: :text
    = f.input :phone, label: t('.phone'), as: :text


  .form-actions
    = f.button :submit
